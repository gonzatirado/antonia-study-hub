rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/usage/{period} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/subjects/{subjectId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/summaries/{summaryId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/quizzes/{quizId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/schedule/{blockId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/examPreps/{prepId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /grades/{gradeId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    match /pendings/{pendingId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
